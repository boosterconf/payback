{
  "name": "booster-payback-time",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "echo 'No build step'",
    "check": "tsc --noEmit",
    "dev": "vercel env pull .env.local --yes && bun --hot src/server.ts",
    "bundle:blob": "bunx esbuild node_modules/@vercel/blob/dist/client.js --bundle --format=esm --minify --outfile=public/blob-client.js"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/oauth-providers": "^0.8.5",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/blob": "^2.3.2",
    "hono": "^4.12.9"
  }
}
